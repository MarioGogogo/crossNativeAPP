  background-color: #f59e0b;
  color: #ffffff;
}

.info-box {
  flex-direction: row;
  padding-top: 12rpx;
  padding-bottom: 12rpx;
  border-bottom-width: 1rpx;
  border-bottom-color: #e2e8f0;
}

