  padding-left: 24rpx;
  padding-right: 24rpx;
  padding-top: 16rpx;
  padding-bottom: 16rpx;
  border-radius: 8rpx;
  font-size: 24rpx;
  margin-right: 16rpx;
  margin-bottom: 12rpx;
  text-align: center;
}

.btn-small {
  padding-left: 16rpx;
  padding-right: 16rpx;
  padding-top: 8rpx;
  padding-bottom: 8rpx;
  font-size: 22rpx;
}

.btn-primary {
  background-color: #3b82f6;
  color: #ffffff;
}

.btn-secondary {
  background-color: #64748b;
  color: #ffffff;
}

.btn-info {
  background-color: #0ea5e9;
  color: #ffffff;
}

.btn-success {
  background-color: #10b981;
  color: #ffffff;
}

.btn-warning {
  background-color: #f59e0b;
  color: #ffffff;
}

.info-box {
  flex-direction: row;
  padding-top: 12rpx;
  padding-bottom: 12rpx;
  border-bottom-width: 1rpx;
  border-bottom-color: #e2e8f0;
}

.info-label {
  font-size: 24rpx;
  color: #64748b;
  width: 140rpx;
}

.info-value {
  font-size: 24rpx;
  color: #1e293b;
  flex: 1;
}

.input-group {
  margin-top: 16rpx;

  position: relative;
}

.input {
  background-color: #f1f5f9;
  border-width: 1rpx;
  border-color: #e2e8f0;
  border-radius: 8rpx;
  padding-left: 16rpx;
  padding-right: 16rpx;
  height: 72rpx;
  font-size: 24rpx;
  color: #1e293b;
}

.hidden-input {
  position: absolute;
  opacity: 0;
  width: 100%;
  height: 100%;
  left: 0;
  top: 0;
}

.log-container {
  width: 710rpx;
  height: 400rpx;
  background-color: #ffffff;
  border-radius: 8rpx;
  padding: 20rpx;
  border-width: 1rpx;
  border-color: #e2e8f0;
}

.log-item {
  flex-direction: column;
  padding-top: 12rpx;
  padding-bottom: 12rpx;
  border-bottom-width: 1rpx;
  border-bottom-color: #e2e8f0;
}

.log-row {
  flex-direction: row;
  /* nvue 不支持百分比宽度，100%会被忽略导致宽度为 0；改用 flex:1 占满父容器 */
  flex: 1;
}

.log-time {
  font-size: 24rpx;
  color: #64748b;
  width: 160rpx;
  /* nvue 中 line-height 须为绝对单位，1.5 无效 */
  line-height: 44rpx;
}

.log-msg {
  flex: 1;
  font-size: 28rpx;
  font-weight: 500;
  /* 移除固定 height，避免截断；line-height 须为绝对单位 */
  line-height: 44rpx;
  /* 默认颜色兑底：防止动态颜色类未生效时文字隱形 */
  color: #334155;
}

.log-info {
  color: #334155;
}

.log-out {
  color: #059669;
}

.log-in {
  color: #2563eb;
}

.log-error {
  color: #dc2626;
  font-weight: bold;
}
</style>