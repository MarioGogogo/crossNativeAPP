{
	"name": "UniWebView",
	"id": "uniplugin_webview",
	"version": "1",
	"description": "原生webview插件描述,安卓和ios共用",
	"_dp_type": "nativeplugin",
	"_dp_nativeplugin": {
		"android": {
			"plugins": [
				{
					"type": "component",
					"name": "UniWebView",
					"class": "uni.dcloud.io.uniplugin_webview.WebViewComponent"
				},
				{
					"type": "module",
					"name": "UniWebViewModule",
					"class": "uni.dcloud.io.uniplugin_webview.WebViewModule"
				},
				{
					"type": "component",
					"name": "X5WebView",
					"class": "uni.dcloud.io.uniplugin_webview.X5WebViewComponent"
				},
				{
					"type": "module",
					"name": "X5WebViewModule",
					"class": "uni.dcloud.io.uniplugin_webview.X5WebViewModule"
				},
				{
					"type": "module",
					"name": "X5LocalInstallModule",
					"class": "uni.dcloud.io.uniplugin_webview.X5LocalInstallModule"
				}
			],
			"minSdkVersion": "22",
			"integrateType": "aar",
			"dependencies": []
		},
		"ios": {
			"plugins": [
				{
					"type": "component",
					"name": "UniWebView",
					"class": "UniWebViewComponent"
				}
			],
			"frameworks": [],
			"integrateType": "framework",
			"deploymentTarget": "15.0"
		}
	}
}